# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your-256-bit-secret-here

# ── AI Providers ──────────────────────────────────────────────────────────────
# Groq — console.groq.com → API Keys → Create
GROQ_API_KEY=

# Gemini Vision (optional, OCR only) — aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Cerebras — cloud.cerebras.ai → API Keys
CEREBRAS_API_KEY=

# SambaNova — cloud.sambanova.ai → API
SAMBANOVA_API_KEY=

# OpenRouter — openrouter.ai → Keys
OPENROUTER_API_KEY=

# GitHub Models — github.com/settings/tokens (needs Models: Read permission)
GITHUB_TOKEN=

# Helicone observability — helicone.ai → API Keys
HELICONE_API_KEY=

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password

# ── App URLs ──────────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173
PORT=5000
NODE_ENV=development
